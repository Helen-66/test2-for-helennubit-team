.container { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }
.status-bar { display: flex; justify-content: space-between; align-items: center; background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.status-text { font-size: 28rpx; color: #333; }
.section { margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 16rpx; color: #333; }
.empty { text-align: center; padding: 40rpx; color: #999; font-size: 26rpx; background: #fff; border-radius: 16rpx; }
.order-list { display: flex; flex-direction: column; gap: 16rpx; }
.order-card { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.order-info { display: flex; flex-direction: column; gap: 8rpx; margin-bottom: 16rpx; }
.user-name { font-size: 28rpx; font-weight: bold; color: #333; }
.service-date { font-size: 24rpx; color: #666; }
.service-addr { font-size: 24rpx; color: #999; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.amount { font-size: 28rpx; color: #4A90D9; font-weight: bold; }
.status-tag { font-size: 22rpx; color: #4A90D9; background: #EBF3FD; padding: 4rpx 12rpx; border-radius: 4rpx; align-self: flex-start; }
.order-btns { display: flex; gap: 16rpx; justify-content: flex-end; }
.btn-accept { background: #4A90D9; color: #fff; font-size: 24rpx; }
.btn-reject { background: #fff; color: #999; border: 1rpx solid #ddd; font-size: 24rpx; }
.btn-signin { background: #67C23A; color: #fff; font-size: 24rpx; }
.btn-complete { background: #4A90D9; color: #fff; font-size: 24rpx; }
