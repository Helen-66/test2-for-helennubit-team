<view class="container">
  <view wx:if="{{!isLogged}}" class="login-section">
    <text class="login-title">登录后开始接单赚钱</text>
    <button class="btn-login" bindtap="login">微信一键登录</button>
  </view>

  <view wx:else class="profile-section">
    <view class="user-card">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/default-avatar.png'}}" />
      <view class="user-info">
        <text class="nickname">{{sitterInfo.realName || userInfo.nickname || '未设置'}}</text>
        <text class="audit-status" wx:if="{{sitterInfo}}">
          {{sitterInfo.auditStatus === 0 ? '审核中' : sitterInfo.auditStatus === 1 ? '已认证' : '审核未通过'}}
        </text>
        <text class="audit-status" wx:else>未认证</text>
      </view>
    </view>

    <view class="stats" wx:if="{{sitterInfo && sitterInfo.auditStatus === 1}}">
      <view class="stat-item">
        <text class="stat-num">{{sitterInfo.orderCount}}</text>
        <text class="stat-label">完成订单</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{sitterInfo.rating}}</text>
        <text class="stat-label">评分</text>
      </view>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="goToApply" wx:if="{{!sitterInfo || sitterInfo.auditStatus === 2}}">
        <text>{{sitterInfo ? '重新申请认证' : '申请成为宠托师'}}</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item" bindtap="logout">
        <text>退出登录</text>
        <text class="arrow">></text>
      </view>
    </view>
  </view>
</view>
