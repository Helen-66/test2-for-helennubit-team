.container { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }
.summary { display: flex; background: linear-gradient(135deg, #4A90D9, #6BB5F0); border-radius: 16rpx; padding: 40rpx 20rpx; margin-bottom: 20rpx; }
.summary-item { flex: 1; text-align: center; }
.summary-item .amount { display: block; font-size: 36rpx; font-weight: bold; color: #fff; }
.summary-item .amount.settled { color: #C8E6C9; }
.summary-item .amount.pending { color: #FFE0B2; }
.summary-item .label { display: block; font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }
.section { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.empty { text-align: center; padding: 40rpx; color: #999; font-size: 26rpx; }
.income-list { display: flex; flex-direction: column; }
.income-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.income-info { display: flex; flex-direction: column; }
.order-no { font-size: 24rpx; color: #333; }
.date { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.income-right { text-align: right; }
.income-amount { display: block; font-size: 30rpx; color: #4A90D9; font-weight: bold; }
.settle-status { display: block; font-size: 20rpx; color: #FF9800; margin-top: 4rpx; }
.settle-status.done { color: #4CAF50; }
.tip { text-align: center; font-size: 22rpx; color: #999; margin-top: 20rpx; }
