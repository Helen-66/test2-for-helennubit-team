.container { padding-bottom: 120rpx; background: #f5f5f5; min-height: 100vh; }
.profile { display: flex; padding: 30rpx; background: #fff; align-items: center; }
.profile .avatar { width: 140rpx; height: 140rpx; border-radius: 50%; margin-right: 24rpx; }
.profile .info { flex: 1; }
.profile .name { font-size: 34rpx; font-weight: bold; display: block; }
.profile .rating { font-size: 24rpx; color: #FF8C42; display: block; margin-top: 8rpx; }
.profile .address { font-size: 22rpx; color: #999; display: block; margin-top: 8rpx; }
.section { background: #fff; margin-top: 20rpx; padding: 24rpx 30rpx; }
.section-title { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 20rpx; }
.service-list { display: flex; flex-direction: column; gap: 16rpx; }
.service-item { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.service-name { font-size: 28rpx; color: #333; }
.service-price { font-size: 28rpx; color: #FF8C42; font-weight: bold; }
.review-list { display: flex; flex-direction: column; gap: 20rpx; }
.review-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.review-header { display: flex; align-items: center; gap: 12rpx; }
.review-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; }
.review-name { font-size: 24rpx; color: #666; flex: 1; }
.review-rating { font-size: 22rpx; color: #FF8C42; }
.review-content { font-size: 26rpx; color: #333; margin-top: 10rpx; display: block; }
.footer { position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 30rpx; background: #fff; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05); }
.btn-order { background: #FF8C42; color: #fff; border-radius: 44rpx; font-size: 32rpx; height: 88rpx; line-height: 88rpx; }
