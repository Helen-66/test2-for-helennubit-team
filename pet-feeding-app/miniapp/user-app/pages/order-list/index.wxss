.container { background: #f5f5f5; min-height: 100vh; }
.tabs { display: flex; background: #fff; padding: 20rpx 0; position: sticky; top: 0; z-index: 10; }
.tab { flex: 1; text-align: center; font-size: 26rpx; color: #666; padding: 10rpx 0; }
.tab.active { color: #FF8C42; font-weight: bold; border-bottom: 4rpx solid #FF8C42; }
.empty { text-align: center; padding: 100rpx 0; color: #999; }
.order-list { padding: 20rpx; display: flex; flex-direction: column; gap: 20rpx; }
.order-card { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.order-header { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.order-no { font-size: 22rpx; color: #999; }
.order-status { font-size: 24rpx; color: #FF8C42; font-weight: bold; }
.order-body { display: flex; flex-direction: column; gap: 8rpx; }
.sitter-name { font-size: 28rpx; color: #333; }
.service-date { font-size: 24rpx; color: #666; }
.amount { font-size: 32rpx; color: #FF8C42; font-weight: bold; margin-top: 8rpx; }
.order-actions { display: flex; justify-content: flex-end; margin-top: 16rpx; gap: 16rpx; }
.btn-cancel { font-size: 24rpx; color: #999; border: 1rpx solid #ddd; }
