<view class="container">
  <view wx:if="{{!isLogged}}" class="login-section">
    <text class="login-title">登录后享受更多服务</text>
    <button class="btn-login" bindtap="login">微信一键登录</button>
  </view>

  <view wx:else class="profile-section">
    <view class="user-card">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/default-avatar.png'}}" />
      <view class="user-info">
        <text class="nickname">{{userInfo.nickname || '未设置昵称'}}</text>
        <text class="phone">{{userInfo.phone || '未绑定手机号'}}</text>
      </view>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="goToPets">
        <text>我的宠物</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToSitterApply">
        <text>成为宠托师</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item" bindtap="logout">
        <text>退出登录</text>
        <text class="arrow">></text>
      </view>
    </view>
  </view>
</view>
