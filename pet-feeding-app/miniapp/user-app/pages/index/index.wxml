<view class="container">
  <view class="header">
    <text class="title">附近3公里宠托师</text>
    <text class="sub">为您的爱宠找到最近的喂养师</text>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>定位中...</text>
  </view>

  <view wx:elif="{{sitters.length === 0}}" class="empty">
    <text>附近暂无可用宠托师</text>
  </view>

  <view wx:else class="sitter-list">
    <view class="sitter-card" wx:for="{{sitters}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="avatar" src="{{item.user.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
      <view class="info">
        <view class="name-row">
          <text class="name">{{item.realName}}</text>
          <text class="rating">{{item.rating}}分</text>
        </view>
        <text class="address">{{item.address}}</text>
        <view class="tags">
          <text class="tag" wx:for="{{item.serviceItems}}" wx:for-item="service" wx:key="name">{{service.name}} ¥{{service.price}}/{{service.unit}}</text>
        </view>
        <view class="bottom-row">
          <text class="distance">{{item.distance > 1000 ? (item.distance/1000).toFixed(1) + 'km' : item.distance + 'm'}}</text>
          <text class="order-count">已服务{{item.orderCount}}次</text>
        </view>
      </view>
    </view>
  </view>
</view>
