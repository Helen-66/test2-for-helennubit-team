.container { background: #f5f5f5; min-height: 100vh; }
.login-section { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.login-title { font-size: 30rpx; color: #666; margin-bottom: 40rpx; }
.btn-login { background: #FF8C42; color: #fff; border-radius: 44rpx; width: 400rpx; }
.profile-section { padding: 0; }
.user-card { display: flex; align-items: center; padding: 40rpx 30rpx; background: linear-gradient(135deg, #FF8C42, #FFB347); }
.user-card .avatar { width: 120rpx; height: 120rpx; border-radius: 50%; margin-right: 24rpx; border: 4rpx solid #fff; }
.user-info { flex: 1; }
.nickname { font-size: 34rpx; color: #fff; font-weight: bold; display: block; }
.phone { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; display: block; }
.menu-list { margin-top: 20rpx; background: #fff; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.menu-item text { font-size: 28rpx; color: #333; }
.arrow { color: #ccc !important; }
