.container { padding: 24rpx; padding-bottom: 160rpx; background: #f5f5f5; min-height: 100vh; }
.section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.pet-list, .service-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.pet-item, .service-item { padding: 16rpx 24rpx; border: 2rpx solid #e0e0e0; border-radius: 8rpx; font-size: 26rpx; }
.pet-item.selected, .service-item.selected { border-color: #FF8C42; background: #FFF3E8; color: #FF8C42; }
.service-item { display: flex; justify-content: space-between; width: 100%; }
.service-item .price { color: #FF8C42; }
.date-row { display: flex; align-items: center; gap: 16rpx; }
.date-picker { padding: 16rpx 24rpx; background: #f5f5f5; border-radius: 8rpx; font-size: 26rpx; min-width: 200rpx; text-align: center; }
.date-sep { font-size: 26rpx; color: #999; }
.field { display: flex; justify-content: space-between; align-items: center; margin-top: 20rpx; font-size: 28rpx; }
.input-sm { width: 120rpx; text-align: center; border-bottom: 2rpx solid #e0e0e0; font-size: 28rpx; }
.address-row { padding: 20rpx; background: #f5f5f5; border-radius: 8rpx; }
.placeholder { color: #999; }
.textarea { width: 100%; height: 120rpx; font-size: 26rpx; padding: 16rpx; background: #f5f5f5; border-radius: 8rpx; }
.tip { font-size: 24rpx; color: #999; }
.footer { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; padding: 20rpx 30rpx; background: #fff; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05); }
.amount { flex: 1; font-size: 28rpx; }
.amount-num { color: #FF8C42; font-size: 36rpx; font-weight: bold; }
.btn-submit { background: #FF8C42; color: #fff; border-radius: 44rpx; font-size: 30rpx; padding: 0 50rpx; height: 80rpx; line-height: 80rpx; }
